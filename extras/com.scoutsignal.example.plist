<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.scoutsignal</string>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>/tmp/scoutsignal.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/scoutsignal.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>/REPLACE/WITH/VENV/bin/scoutsignal</string>
    <string>run</string>
    <string>--config</string>
    <string>/REPLACE/WITH/scoutsignal-config/config.yaml</string>
    <string>--chats</string>
    <string>/REPLACE/WITH/scoutsignal-config/chats.yaml</string>
  </array>
</dict>
</plist>
